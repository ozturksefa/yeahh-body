VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Web Push (see README for how to generate VAPID keys)
VITE_VAPID_PUBLIC_KEY=your-base64-public-key

# Server-side only (Netlify env, never shipped to client):
# VAPID_PUBLIC_KEY=your-base64-public-key
# VAPID_PRIVATE_KEY=your-base64-private-key
# VAPID_SUBJECT=mailto:admin@yeahh.body
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
